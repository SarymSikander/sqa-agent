BASE_URL=https://staging.myzambeel.com

# JWT secret — must match the JWT_SECRET value in zambeel-api's config.
# Used ONLY to generate expired tokens for auth dimension tests.
JWT_SECRET=

# Firebase Web API Key — used to exchange email+password for a Firebase idToken.
# Found in Firebase console > Project Settings > General > Web API Key.
FIREBASE_API_KEY=

# ── Staging credentials ───────────────────────────────────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=

SELLER_EMAIL=
SELLER_PASSWORD=

AGENCY_EMAIL=
AGENCY_PASSWORD=

# ── Stable staging entity IDs ─────────────────────────────────────────────────
# IDs of records that exist in staging and will not be deleted or mutated.
TEST_ORDER_ID=
TEST_TICKET_ID=
TEST_TICKET_STORE_ID=
TEST_VARIANT_ID=

# ── Route discovery (scripts/discover-routes.js only) ────────────────────────
# Absolute path to the zambeel-api source repository on your machine.
# Not used during test runs — only needed when regenerating api-inventory.json.
API_REPO_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION SMOKE TESTS  (jest --config jest.smoke.js)
# ─────────────────────────────────────────────────────────────────────────────

PROD_BASE_URL=https://portal.myzambeel.com
PROD_FIREBASE_API_KEY=

PROD_ADMIN_EMAIL=
PROD_ADMIN_PASSWORD=

PROD_SELLER_EMAIL=
PROD_SELLER_PASSWORD=

PROD_AGENCY_EMAIL=
PROD_AGENCY_PASSWORD=

# Production JWT secret — used ONLY to generate expired tokens for auth tests.
PROD_JWT_SECRET=

# Stable production entity IDs — used by scripts/calibrate-sla.js and
# scripts/measure-baselines.js to substitute path params in GET endpoints.
PROD_SAMPLE_ORDER_ID=
PROD_SAMPLE_TICKET_ID=
PROD_TICKET_STORE_ID=
PROD_VARIANT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# SLACK INTEGRATIONS
# ─────────────────────────────────────────────────────────────────────────────

# Incoming Webhook URL — used by scripts/slack-notify.js for CI smoke alerts.
SLACK_WEBHOOK_URL=

# Bot token — used by the live Slack agent (scripts/slack-agent.js).
# Format: xoxb-...
SLACK_BOT_TOKEN=

# App-level token for Socket Mode.
# Format: xapp-...
SLACK_APP_TOKEN=
