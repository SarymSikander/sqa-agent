# ── App ──────────────────────────────────────────────────
SESSION_SECRET=your-random-secret-here
SQA_USERS=[{"email":"admin@yourcompany.com","password":"bcrypt-hashed-password"}]

# ── Portal URLs ──────────────────────────────────────────
STAGING_URL=https://staging.yourproduct.com
PRODUCTION_URL=https://yourproduct.com
LOCAL_URL=http://localhost:3000

# ── API URLs ─────────────────────────────────────────────
STAGING_API_URL=https://staging.yourproduct.com
PRODUCTION_API_URL=https://yourproduct.com

# ── Portal Credentials (Staging) ─────────────────────────
SELLER_STAGING_EMAIL=seller@test.com
SELLER_STAGING_PASSWORD=yourpassword
ADMIN_STAGING_EMAIL=admin@test.com
ADMIN_STAGING_PASSWORD=yourpassword
AGENCY_STAGING_EMAIL=agency@test.com
AGENCY_STAGING_PASSWORD=yourpassword

# ── Portal Credentials (Production) ──────────────────────
SELLER_PRODUCTION_EMAIL=seller@yourcompany.com
SELLER_PRODUCTION_PASSWORD=yourpassword
ADMIN_PRODUCTION_EMAIL=admin@yourcompany.com
ADMIN_PRODUCTION_PASSWORD=yourpassword
AGENCY_PRODUCTION_EMAIL=agency@yourcompany.com
AGENCY_PRODUCTION_PASSWORD=yourpassword

# ── Jira ─────────────────────────────────────────────────
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token

# ── AI Models ────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
GITHUB_TOKEN=your-github-token-for-azure-gpt4o

# ── Slack ────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# ── Database (optional) ──────────────────────────────────
PRODUCTION_DB_HOST=your-db-host
PRODUCTION_DB_PORT=3306
PRODUCTION_DB_USER=your-db-user
PRODUCTION_DB_PASSWORD=your-db-password
PRODUCTION_DB_NAME=your-db-name

# ── GitHub Repos ─────────────────────────────────────────
GITHUB_FRONTEND_REPO=owner/frontend-repo
GITHUB_BACKEND_REPO=owner/backend-repo
