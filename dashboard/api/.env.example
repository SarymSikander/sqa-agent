GITHUB_TOKEN=
GITHUB_REPO=SarymSikander/api-test-suite
GITHUB_WORKFLOW_FILE=api-tests.yml

# JWT signing secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Bcrypt-hashed user list — add entries with: python3 scripts/add-user.py email@example.com password
# Example: [{"email":"you@example.com","password":"$2b$12$..."}]
SQA_USERS=[]
